# Freebie Finder — environment template.
# Copy to .env.local and fill in. Placeholders only; never commit real values.

# --- Core (required) ---

# Postgres connection string (Neon works on the free tier).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# NextAuth v5 session/JWT secret — generate with: npx auth secret
AUTH_SECRET="GENERATE_WITH_npx_auth_secret"

# Shared bearer secret the GitHub Actions crons send to /api/poll, /api/digest,
# /api/ingest-reddit — any long random string.
CRON_SECRET="ANY_LONG_RANDOM_STRING"

# Public base URL of the deployed app (used in emails/links; falls back to
# NEXTAUTH_URL, then http://localhost:3000).
APP_URL="https://your-app.vercel.app"

# --- Telegram channel delivery (optional; off when unset) ---

# Bot token from @BotFather; the bot must be an admin of the channel.
TELEGRAM_BOT_TOKEN="123456789:YOUR_BOT_TOKEN"

# Public channel id or @username the bot posts to.
TELEGRAM_CHANNEL_ID="@your_channel"

# --- Discord delivery (optional) ---

# Channel webhook URL (Server Settings -> Integrations -> Webhooks).
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/YOUR_WEBHOOK"

# Public invite link shown on the homepage.
DISCORD_INVITE_URL="https://discord.gg/YOUR_INVITE"

# --- Email: magic-link sign-in + per-user digests (optional) ---

# Resend API key (https://resend.com).
RESEND_API_KEY="re_YOUR_RESEND_KEY"

# From address for auth + digest emails (must be a verified Resend sender).
EMAIL_FROM="Freebie Finder <onboarding@resend.dev>"

# --- Web push (optional) — generate pair with: npx web-push generate-vapid-keys ---

# VAPID public key (server side).
VAPID_PUBLIC_KEY="YOUR_VAPID_PUBLIC_KEY"

# VAPID private key — keep secret.
VAPID_PRIVATE_KEY="YOUR_VAPID_PRIVATE_KEY"

# Contact for push services, mailto: or URL.
VAPID_SUBJECT="mailto:you@example.com"

# Same public key again, exposed to the browser for the subscribe call.
NEXT_PUBLIC_VAPID_PUBLIC_KEY="YOUR_VAPID_PUBLIC_KEY"

# --- AI digest overview (optional) ---

# Gemini API key from Google AI Studio; digest falls back to no AI overview.
GEMINI_API_KEY="AIza_YOUR_GEMINI_KEY"

# Optional model pin; when unset the newest free Flash model is auto-resolved.
SUMMARY_MODEL=""
